# Use local mock data instead of fetching from WordPress.
# Set to "true" during local development when the WP API is unavailable.
VITE_USE_MOCK=false

# WordPress REST API base URL.
# Defaults to https://content.bkkkapp.com/wp-json/wp/v2 if not set.
VITE_WP_BASE_URL=https://content.bkkkapp.com/wp-json/wp/v2
